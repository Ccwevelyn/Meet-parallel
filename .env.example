# 接 AI 自主聊天：大模型会学习各成员说话方式，在群聊里自动发言
# 复制为 .env 并填写（.env 已加入 .gitignore）
# 推荐用通用变量名 AI_*（用 DeepSeek/智谱等时更直观），也兼容 OPENAI_*

# 必填：API 密钥（任一即可）
AI_API_KEY=sk-xxx

# 选填：接口地址、模型名
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# ——— 示例：DeepSeek ———
# AI_API_KEY=sk-你的DeepSeek密钥
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# 智谱 GLM
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-flash

# 月之暗面 Moonshot
# AI_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-8k

# 选填：管理员密码，默认 Cc921
# ADMIN_PASSWORD=Cc921
